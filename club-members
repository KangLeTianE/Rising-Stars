<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Rising Star | Club Members</title>
  <style>
    :root {
      --text: #111827;
      --muted: #6b7280;
      --gold-1: #ffd76a;
      --gold-2: #ffb800;
      --gold-3: #ff8a00;
      --blue-1: #4f7cff;
      --blue-2: #7a5cff;
      --line: rgba(17, 24, 39, 0.14);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      min-height: 100vh;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(122, 92, 255, 0.10), transparent 30%),
        radial-gradient(circle at bottom right, rgba(255, 184, 0, 0.14), transparent 30%),
        linear-gradient(180deg, #fcfcfe 0%, #f4f7fb 100%);
      color: var(--text);
    }

    .navbar {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 48px;
      z-index: 999;
      display: flex;
      justify-content: flex-start;
      align-items: stretch;
      padding: 0;
      background: rgba(255, 255, 255, 0.94);
      border-bottom: 1px solid rgba(17, 24, 39, 0.12);
      box-shadow: 0 4px 16px rgba(17, 24, 39, 0.06);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
    }

    .nav-links {
      display: flex;
      align-items: stretch;
      height: 100%;
      gap: 0;
    }

    .nav-links a {
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 22px;
      text-decoration: none;
      color: var(--text);
      font-size: 0.95rem;
      font-weight: 700;
      border-right: 1px solid rgba(17, 24, 39, 0.12);
      border-radius: 0;
      transition: 0.2s ease;
    }

    .nav-links a:first-child {
      border-left: 1px solid rgba(17, 24, 39, 0.12);
    }

    .nav-links a:hover {
      background: rgba(17, 24, 39, 0.06);
    }

    .nav-links a.active {
      color: #ffffff;
      background: linear-gradient(90deg, var(--blue-1), var(--blue-2));
    }

    .page-intro {
      padding: 92px 80px 18px;
    }

    .intro-text {
      max-width: 680px;
    }

    .page-intro h1 {
      font-size: clamp(2.3rem, 4.6vw, 4.7rem);
      line-height: 0.95;
      letter-spacing: -0.04em;
      font-weight: 900;
      margin: 0 0 12px;
      background: linear-gradient(90deg, var(--blue-1), var(--blue-2), var(--gold-2));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .page-intro p {
      max-width: 540px;
      color: var(--muted);
      font-size: 0.98rem;
      line-height: 1.65;
      margin: 0;
    }

    .members {
      width: 100%;
    }

    .member-section {
      display: grid;
      grid-template-columns: minmax(250px, 31vw) minmax(300px, 390px) 1fr;
      align-items: start;
      column-gap: clamp(24px, 3.5vw, 48px);
      padding: 38px 80px;
      border-top: 1px solid var(--line);
    }

    .member-section:last-child {
      border-bottom: 1px solid var(--line);
    }

    .member-photo {
      width: 100%;
      height: min(60vh, 520px);
      min-height: 380px;
      border-radius: 30px;
      overflow: hidden;
      position: relative;
      box-shadow:
        0 24px 64px rgba(17, 24, 39, 0.14),
        0 10px 24px rgba(79, 124, 255, 0.12);
      background: rgba(255, 255, 255, 0.5);
    }

    .member-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: saturate(1.04) contrast(1.02);
    }

    .member-content {
      max-width: 390px;
      padding-top: 6px;
    }

    .info-block {
      border-top: 1px solid var(--line);
    }

    .info-row {
      padding: 18px 0;
      border-bottom: 1px solid var(--line);
    }

    .field-label {
      display: block;
      margin-bottom: 7px;
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--blue-1);
    }

    .member-name {
      font-size: clamp(1.8rem, 3.3vw, 3.7rem);
      line-height: 0.95;
      letter-spacing: -0.06em;
      font-weight: 900;
      color: var(--text);
    }

    .member-about {
      color: var(--muted);
      font-size: 0.94rem;
      line-height: 1.75;
      max-width: 360px;
    }

    @media (max-width: 900px) {
      .page-intro {
        padding: 92px 28px 20px;
      }

      .member-section {
        grid-template-columns: minmax(220px, 340px) minmax(260px, 1fr);
        column-gap: 28px;
        padding: 34px 28px;
      }

      .member-photo {
        height: 480px;
        min-height: 340px;
      }
    }

    @media (max-width: 680px) {
      .nav-links a {
        font-size: 0.85rem;
        padding: 0 14px;
      }

      .page-intro {
        padding: 88px 24px 18px;
      }

      .member-section {
        grid-template-columns: 1fr;
        row-gap: 22px;
        padding: 34px 24px;
      }

      .member-photo {
        height: 420px;
        min-height: 300px;
        border-radius: 24px;
      }

      .member-content {
        max-width: 100%;
        padding-top: 0;
      }

      .member-about {
        max-width: 100%;
      }
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="nav-links">
      <a href="index.html">Home</a>
      <a href="club-members.html" class="active">Club Members</a>
    </div>
  </nav>

  <header class="page-intro">
    <div class="intro-text">
      <h1>Club Members</h1>
      <p>
        Meet the kids who host Rising Star’s online discussion meetings.
      </p>
    </div>
  </header>

  <main class="members">
    <section class="member-section">
      <div class="member-photo">
        <img
          src="https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?auto=format&fit=crop&w=900&q=80"
          alt="Club member"
        />
      </div>

      <div class="member-content">
        <div class="info-block">
          <div class="info-row">
            <span class="field-label">Name</span>
            <h2 class="member-name">Alex</h2>
          </div>

          <div class="info-row">
            <span class="field-label">About</span>
            <p class="member-about">
              Alex enjoys sharing ideas, listening to others, and helping everyone
              feel comfortable during discussions.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="member-section">
      <div class="member-photo">
        <img
          src="https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?auto=format&fit=crop&w=900&q=80"
          alt="Club member"
        />
      </div>

      <div class="member-content">
        <div class="info-block">
          <div class="info-row">
            <span class="field-label">Name</span>
            <h2 class="member-name">Emma</h2>
          </div>

          <div class="info-row">
            <span class="field-label">About</span>
            <p class="member-about">
              Emma likes learning from other people’s opinions and making online
              meetings feel friendly and welcoming.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="member-section">
      <div class="member-photo">
        <img
          src="https://images.unsplash.com/photo-1542810634-71277d95dcbb?auto=format&fit=crop&w=900&q=80"
          alt="Club member"
        />
      </div>

      <div class="member-content">
        <div class="info-block">
          <div class="info-row">
            <span class="field-label">Name</span>
            <h2 class="member-name">Noah</h2>
          </div>

          <div class="info-row">
            <span class="field-label">About</span>
            <p class="member-about">
              Noah enjoys asking questions, hearing new ideas, and helping group
              conversations stay active and thoughtful.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</body>
</html>
